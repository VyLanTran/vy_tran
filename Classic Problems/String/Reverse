public class Reverse {

	public static String reverse(String str) {
		if (str.length() == 0) {
			return "";
		} 
		if (str.contains(" ") == false) {
			return str;
		}
		
		int space_index = str.indexOf(" ");
		String first_word = str.substring(0, space_index);
		String new_str = str.substring(space_index + 1);
		return reverse(new_str) + " " + first_word;
	}
	
	public static void main(String args[]) {
		System.out.println(reverse("a sky is blue"));
	}
}
