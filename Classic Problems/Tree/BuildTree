public class SolutionTest {
	
	public static void main(String args[]) {
		Solution s = new Solution();
		int[] pre = new int[] {3,9,20,15,7};
		int[] in = new int[] {9,3,15,20,7};
		BinaryTree tree = s.buildTree(pre, in);
		System.out.println(tree.root.data);
		System.out.println(tree.root.left.data);
		System.out.println(tree.root.right.data);
	}
	
}


class Solution {
	
	int pre_index = 0;
		
	public BinaryTree buildTree(int[] preorder, int[] inorder) {
		Node root = buildTree(preorder, inorder, 0, preorder.length-1);
		return new BinaryTree(root);
	}

	public Node buildTree(int[]preorder, int[]inorder, int start, int end) {
		// assume that parameters are valid
		Node node = new Node(preorder[pre_index++]);
		// base case
		if (start == end) {
			return node;
		}
		else {
			int in_index = find(inorder, node.data);
			node.left = buildTree(preorder, inorder, start, in_index - 1);
			node.right = buildTree(preorder, inorder, in_index + 1, end);
		}
			
		return node;
	}
	
	public int find(int[] array, int value) {
		for (int i = 0; i < array.length; i++) {
			if (array[i] == value) {
				return i;
			}
		}
		return -1;
	}
}

class BinaryTree {

	Node root;
	
	public BinaryTree() {
		root = null;
	}
	
	public BinaryTree(Node root) {
		this.root = root;
	}
}


class Node {
	
	int data;
	Node left, right;
	
	public Node(int data) {
		this.data = data;
		left = null;
		right = null;
	}
}

