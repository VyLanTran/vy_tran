	public String breadthFirstTraversal() {
		String text = "";
		breadthFirstPush();
		while (bf_stk.top != null) {
			text += bf_stk.peek() + "\s";
			bf_stk.pop();
		}
		return text;
	}
	
	public void breadthFirstPush() {
		int height = height(root);
		for (int i = height; i >= 0; i--) {
			levelPush(root, i);
			for (Object data : levels.keySet()) {
				if (levels.get(data) == -1) {
					levels.put(data, i);
				}
			}
		}
	}
	
	public void levelPush(Node node, int lv) {
		if (node == null) return;
		if (lv == 0) {
			bf_stk.push(node.data);
			levels.put(node.data, -1);	//-1: the level of each node is undefined at first
		}
		else if (lv > 0) {
			levelPush(node.right, lv - 1);
			levelPush(node.left, lv - 1);
		}
	}
	
	public int height(Node node){
        if (node == null || (node.left == null && node.right == null)) 
            return 0;
        else {
            int lheight = height(node.left);
            int rheight = height(node.right);
 
            if (lheight > rheight)
                return (lheight + 1);
            else
                return (rheight + 1);
        }
    }

	public int treeHeight() {
		return height(root);
	}
	
	public int getLevel(Object data) {
		if (! levelMap().containsKey(data.toString())) return -1;
		return levelMap().get(data.toString());
	}
	
	public HashMap<Object, Integer> levelMap() {
		breadthFirstPush();
		return levels;
	}
	
	public int levelSize(int level) {
		HashMap<Object, Integer> map = levelMap();
		int size = 0;
		for (Object data : map.keySet()) {
			if (map.get(data) == level) size++;
		}
		return size;
	}
	
	public int size() {
		int size = 0;
		for (int i = 0; i <= treeHeight(); i++) {
			size += levelSize(i);
		}
		return size;
	}
	
	public boolean isComplete() {
		int i = 0;
		while (i <= treeHeight()) {
			if (levelSize(i) != Math.pow(2, i)) {
				return false;
			}
			i++;
		}
		return true;
	}
}
