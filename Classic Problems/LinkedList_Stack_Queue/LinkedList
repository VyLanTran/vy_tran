	//2.
	public boolean hasLoop() {
		if (head == null) return false;
		ArrayList<Node> nodes = new ArrayList<Node>();
		Node cur = head;
		Node next = null;
		
		while (cur != null) {
			nodes.add(cur);
			next = cur.next;
			if (nodes.contains(next)) {
				return true;
			}
			cur = next;
		}
		return false;
	}
}
