public class StackFromLinkedList {
	public Node top;
	
	public StackFromLinkedList() {
		top = null;
	}
	
	public void push(Object value) {
		Node new_node = new Node(value);
		new_node.next = top;
		top = new_node;
	}
	
	public void pop() {
		if (top == null) {
			return;
		}
		else top = top.next;
	}
	
	public Object peek() {
		return top.data;
	}
	
	public String display() {
		String text = "";
		Node cur = top;
		while (cur != null) {
			text += cur.data + "\s";
			cur = cur.next;
		}
		return text;
	}
}
