package LinkedList_Stack_Queue;

public class QueueFromLinkedList {

	Node front;
	Node back;
	
	public QueueFromLinkedList() {
		front = null;
		back = null;
	}
	
	public void enqueue(Node node) {
		if (front == null) {
			front = node;
			back = node;
		}
		else {
			back.next = node;
			back = node;
		}
	}
	
	public void enqueue(Object value) {
		Node new_node = new Node(value);
		if (front == null) {
			front = new_node;
			back = new_node;
		}
		else {
			back.next = new_node;
			back = new_node;
		}
	}
	
	public void dequeue() {
		if (front == null) return;
		front = front.next;
		if (front == null) back = null;
	}
	
	public Node peek() {
		return front;
	}
	
	public boolean is_empty() {
		return front == null;
	}
	
	public String display() {
		String text = "";
		Node cur = front;
		while (cur != null) {
			text += cur.data + "\s";
			cur = cur.next;
		}
		return text;
	}
}
