package LinkedList_Stack_Queue;

public class QueueFromStack {

	StackFromLinkedList main_qu;
	StackFromLinkedList helper_qu;

	public QueueFromStack() {
		main_qu = new StackFromLinkedList();
		helper_qu = new StackFromLinkedList();
	}
	
	public void enqueue(Object value) {
		while (!main_qu.is_empty()) {
			helper_qu.push(main_qu.peek().data);
			main_qu.pop();
		}
		main_qu.push(value);
		while (!helper_qu.is_empty()) {
			main_qu.push(helper_qu.peek().data);
			helper_qu.pop();
		}
	}
	
	public void dequeue() {
		main_qu.pop();
	}
	
	public Node peek() {
		return main_qu.peek();
	}
	
	public String display() {
		return main_qu.display();
	}
}
