package HW4;

public class Problem3Test {

	public static void main(String args[]) {
		Solution3 s = new Solution3();
		int[] arr = new int[] {1, 2, 3, 4, 5, 5, 5, 6, 7};
		int value = 5;
		System.out.println("Number of elements less than or equal to " + value + ": " 
							+ s.num_less_equal(arr, value));
	}

}

class Solution3 {
	// Find the number of elements less than or equal to a value
	public int num_less_equal(int[] numbers, int value) {
		int index = binary_search(numbers, value);
		return index + 1;
	}
	
	public int binary_search(int[] numbers, int value) {
		return binary_search(numbers, value, 0, numbers.length - 1);
	}
	
	public int binary_search(int[] numbers, int value, int start, int end) {
		if (start > end) return -1;
		
		int mid = start + (end - start) / 2;
		// in case there're more than 1 numbers = value
		if (value == numbers[mid]) {
			if (value != numbers[mid + 1]) {
				// this means we already found the last possible number
				return mid;
			}
			else {
				// continue to find on the right half
				return binary_search(numbers, value, mid + 1, end);
			}
		}
		else if (value < numbers[mid]) {
			return binary_search(numbers, value, start, mid - 1);
		}
		else {
			return binary_search(numbers, value, mid + 1, end);
		}
	}
}
