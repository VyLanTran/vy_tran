	public static void main(String[] args) {
		List s = new List(10);
		System.out.println("Before sorting: " + s.display());
		s.selection_sort();
		s.insertion_sort();
		s.merge_sort();
		s.quicksort();
		System.out.println("After sorting: " + s.display());
		
