public class NthToTheLast {
	public static Node NthLast(LinkedList l, int nth) {
		int length = l.length();
		int n_th_index = length - nth;
		Node cur = l.head;
		int index = 0;
		while (index != n_th_index) {
			cur = cur.next;
			index += 1;
		}
		return cur;
	}
	
	public static void main(String args[]) {
		LinkedList list = new LinkedList();
		for (int i = 6; i >= 0; i--) {
			list.push(new Node(i).data);
		}
		
		System.out.println(NthLast(list, 3).data);
	}
}

class Node<E> {
	E data;
	Node next;
	
	Node(E data) {
		this.data = data;
		next = null;
	}
}

class LinkedList<E> {
	Node head;
	
	public int length() {
		Node cur = head;
		int count = 0;
		while (cur != null) {
			cur = cur.next;
			count += 1;
		}
		return count;
	}
	
	public void push(E data) {
		Node new_node = new Node(data);
		new_node.next = head;
		head = new_node;
	}
}
