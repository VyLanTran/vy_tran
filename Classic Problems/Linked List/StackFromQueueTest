import java.util.LinkedList;
import java.util.Queue;

class StackFromQueue {
	Queue<Object> main_stack;
	Queue<Object> helper_stack;
	
	public StackFromQueue() {
		main_stack = new LinkedList<Object>();
		helper_stack = new LinkedList<Object>(); 
	}
	
	public boolean isEmpty() {
		return main_stack.isEmpty();
	}
	
	public void push(Object data) {
		helper_stack.add(data);
		while (!main_stack.isEmpty()) {
			helper_stack.add(main_stack.remove());
		}
		Queue<Object> third_stack = new LinkedList<Object>();
		third_stack = helper_stack;
		helper_stack = main_stack;
		main_stack = third_stack;
	}
	
	public Object pop() {
		if (main_stack.isEmpty()) {
			System.out.println("Empty stack, can't pop");
			return null;
		}
		else {
			return main_stack.remove();
		}
	}
	
	public Object peek() {
		if (main_stack.isEmpty()) {
			System.out.println("Empty stack");
			return null;
		}
		else {
			return main_stack.peek();
		}
	}
	
	public void display() {
		System.out.println("Elements from top to bottom");
		for (int i = 0; i < main_stack.size(); i++) {
			System.out.print(main_stack.peek() + "\t");
			main_stack.add(main_stack.remove());
		}
		System.out.println();
	}
}

public class StackFromQueueTest {
	public static void main(String args[]) {
		StackFromQueue stk = new StackFromQueue();

		stk.push(26);
		stk.push("apple");
		stk.push(54);

		stk.pop();
		
		stk.display();
	}
}
