public class Middle {
	public static Node findMiddle(LinkedList l) {
		// Assume that all inputs are linked lists with an odd number of nodes
		Node cur = l.head;
		int middle = (l.length() - 1) / 2;
		for (int i = 0; i < middle; i++) {
			cur = cur.next;
		}
		return cur;
	}
	
	public static void main(String args[]) {
		Node node1 = new Node("a");
		Node node2 = new Node("b");
		Node node3 = new Node("c");
		Node node4 = new Node("d");
		Node node5 = new Node("e");
		
		LinkedList list = new LinkedList();
		list.head = node1;
		node1.next = node2;
		node2.next = node3;
		node3.next = node4;
		node4.next = node5;
		
		System.out.println("The middle node is: " + findMiddle(list).data);
	}
}

class Node {
	Object data;
	Node next;
	
	public Node(Object data) {
		this.data = data;
		next = null;
	}
}

class LinkedList {
	Node head;
	
	public int length() {
		int count = 0;
		Node cur = head;
		while (cur != null) {
			count += 1;
			cur = cur.next;
		}
		return count;
	}
}
