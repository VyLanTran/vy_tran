import java.util.ArrayList;

public class DetectLoop {
	public static boolean hasLoop(LinkedList l) {
		ArrayList<Node> nodes = new ArrayList<Node>();
		Node cur = l.head;
		Node next = null;
		while (cur != null) {
			nodes.add(cur);
			next = cur.next;
			if (nodes.contains(next)) {
				return true;
			}
			cur = next;
		}
		return false;
	}
	
	public static void main(String args[]) {
		LinkedList list = new LinkedList();
		Node node1 = new Node(1);
		Node node2 = new Node(2);
		Node node3 = new Node(3);
		Node node4 = new Node(4);
		Node node5 = new Node(5);
		
		list.head = node1;
		node1.next = node2;
		node2.next = node3;
		node3.next = node4;
		node4.next = node5;
		node5.next = node2;
		
		System.out.println(hasLoop(list));
	}
}

class Node {
	Object data;
	Node next;
	
	Node(Object data) {
		this.data = data;
		next = null;
	}
}

class LinkedList {
	Node head;
	
	public int length() {
		Node cur = head;
		int count = 0;
		while (cur != null) {
			cur = cur.next;
			count += 1;
		}
		return count;
	}
	
	public void push(Object data) {
		Node new_node = new Node(data);
		new_node.next = head;
		head = new_node;
	}
}
