import java.util.Stack;

class QueueFromStack {
	Stack main_queue;
	Stack helper_queue;
	
	public QueueFromStack() {
		main_queue = new Stack();
		helper_queue = new Stack();
	}
	
	public boolean isEmpty() {
		return main_queue.isEmpty();
	}
	
	public void enqueue(Object data) {
		while (!main_queue.isEmpty()) {
			helper_queue.push(main_queue.pop());
		}
		main_queue.push(new Node(data));
		while (!helper_queue.isEmpty()) {
			main_queue.push(helper_queue.pop());
		}
	}
	
	public Object dequeue() {
		if (main_queue.isEmpty()) {
			System.out.println("Empty queue, can't dequeue");
			return null;
		}
		else {
			return ((Node)main_queue.pop()).data;
		}	
	}
	
	public void display() {
		if (main_queue.isEmpty()) {
			System.out.println("Empty queue");
		}
		else {
			Stack clone = (Stack)main_queue.clone();
			while (!clone.isEmpty()) {
				System.out.print(((Node)clone.pop()).data + "\t");
			}
			System.out.println();
		}
	}
}

public class QueueFromStackTest {
	public static void main(String args[]) {
		QueueFromStack q = new QueueFromStack();
		
		q.enqueue(12);
		q.enqueue("pear");
		q.enqueue(22.9);
		q.display();
		
		q.dequeue();
//		
		q.display();
//		System.out.println(q.dequeue());
	}
}

