public class QueueFromLinkedList {
	static Node head;
	static Node tail;
	
	public QueueFromLinkedList() {
		head = null;
		tail = null;
	}
	
	public static boolean isEmpty() {
		return head == null;
	}
	
	public static void enqueue(Object data) {
		Node new_node = new Node(data);
		if (isEmpty()) {
			head = tail = new_node;
		}
		else {
			tail.next = new_node;
			tail = new_node;
		}
	}
	
	public static void dequeue() {
		if (isEmpty()) {
			System.out.println("Empty queue, can't dequeue");
		}
		else if (head == tail) {
			head = null;
			tail = null;
		}
		else {
			head = head.next;
		}
	}
	
	public static void display() {
		if (isEmpty()) {
			System.out.println("Empty queue");
		}
		else {
			Node cur = head;
			while (cur != null) {
				System.out.print(cur.data + "\s");
				cur = cur.next;
			}
			System.out.println();
		}
	}
	
	public static void main(String args[]) {
		QueueFromLinkedList q = new QueueFromLinkedList();
//		System.out.println(q.isEmpty());
//		q.display();
		
		q.enqueue(12);
		q.enqueue("apple");
		q.display();
		
		q.dequeue();
		q.dequeue();
		q.dequeue();
		
		q.display();
		System.out.println(q.head);
	}
}

class Node {
	Object data;
	Node next;
	
	public Node(Object data) {
		this.data = data;
		next = null;
	}
}
