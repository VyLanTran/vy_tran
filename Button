package Minesweeper;

import javax.swing.*;

public class Button extends JButton {

    private int x;
    private int y;
    private int value;
    private boolean open = false;

    public Button(int x, int y, int value) {
        this.x = x;
        this.y = y;
        this.value = value;
    }

    @Override
    public int getX() {
        return x;
    }

    @Override
    public int getY() {
        return y;
    }

    public int getValue() {
        return value;
    }

    public boolean isOpen() {
        return open;
    }

    public void setOpen(boolean open) {
        this.open = open;
    }
}
