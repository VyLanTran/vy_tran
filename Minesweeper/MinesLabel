package NewMineSweeper;

import javax.swing.*;
import java.awt.*;

public class MinesLabel extends JLabel {
    private Board board;
    private int x;
    private int y;
    private int w;
    private int h;
    private int minesNum;

    public MinesLabel() {
        board = new Board();
        x = 0;
        y = 0;
        w = 80;
        h = 50;
        //minesNum = board.getCountdownMines();
    }

    public void paint(Graphics g) {
        Graphics2D g2d = (Graphics2D) g;
        g2d.setColor(Color.WHITE);
        g2d.fillRect(x,y, w, h);
        g2d.setColor(Color.BLACK);
        g2d.drawLine(x, y, x + w, y);   // Top border
        g2d.drawLine(x, y, x, y + h);   // Left border
        g2d.drawLine(x, y + h, x + w, y + h);   // Bottom border
        g2d.drawLine(x + w, y + h, x + w, y);   // Right border

        //minesNum = board.getCountdownMines();

        g2d.setFont(new Font("TimesRoman", Font.PLAIN, 16));
        g2d.drawString(String.valueOf(minesNum), x + w/3, y + h/3);
    }

    public void updateLabel() {

        repaint();
    }
}
