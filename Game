package NewMineSweeper;

import javax.swing.*;
import javax.swing.border.Border;
import java.awt.*;

public class Game {
    private static JFrame frame;
    private static JPanel panel;
    private static JPanel top_panel;
    private static JPanel buttons_panel;
    private static Board board;
    private static JLabel textfield;
    private static JLabel countMines;
    private static JButton restart;

    private static JLabel timer;

    public static void main(String args[]) {
        Dimension dimension = Toolkit.getDefaultToolkit().getScreenSize();

        frame = new JFrame();
        frame.setBounds(0, 0, 600, 750);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setResizable(false);

        int x = (int) (dimension.getWidth() / 3);
        int y = 0;
        frame.setLocation(x, y);

        panel = new JPanel();
        BoxLayout boxLayout = new BoxLayout(panel, BoxLayout.Y_AXIS);
        panel.setLayout(boxLayout);

        top_panel = new JPanel();
        top_panel.setLayout(new BorderLayout());
        top_panel.setBounds(0, 0, 600, 100);

        FlowLayout flowLayout = new FlowLayout(FlowLayout.LEFT, 90, 0);
        buttons_panel = new JPanel();
        buttons_panel.setLayout(flowLayout);
        buttons_panel.setPreferredSize(new Dimension(600, 50));
        buttons_panel.setBackground(new Color(52, 186, 235));

        board = new Board(4, 4);
        board.setPreferredSize(new Dimension(600, 600));

        textfield = new JLabel();
        textfield.setBackground(new Color(13, 33, 54));
        textfield.setForeground(new Color(255, 255, 255));
        textfield.setHorizontalAlignment(JLabel.CENTER);
        textfield.setFont(new Font("MVBoli", Font.PLAIN,60));
        textfield.setText("MINESWEEPER");
        textfield.setOpaque(true);

        top_panel.add(textfield);
        panel.add(top_panel);

        /*JButton restart_button = new JButton("Restart");
        restart_button.setHorizontalAlignment(JButton.CENTER);*/

        // set Mines value ?????????
        countMines = new JLabel();
        countMines.setPreferredSize(new Dimension(80, 50));
        countMines.setBackground(Color.WHITE);
        countMines.setOpaque(true);
        Border blackline = BorderFactory.createLineBorder(Color.black);
        countMines.setBorder(blackline);
        String text = String.valueOf(board.getMines());
        countMines.setFont(new Font("MVBoli", Font.PLAIN, 20));
        countMines.setHorizontalTextPosition(JLabel.CENTER);
        countMines.setText(text);

        restart = new JButton();
        restart.setPreferredSize(new Dimension(80, 50));
        restart.setText("START");

        timer = new JLabel("00:00");
        timer.setFont(new Font("MVBoli", Font.PLAIN, 20));
        timer.setHorizontalTextPosition(JLabel.CENTER);
        timer.setPreferredSize(new Dimension(80, 50));
        timer.setBackground(Color.WHITE);
        timer.setOpaque(true);
        timer.setBorder(blackline);

        buttons_panel.add(countMines);
        buttons_panel.add(restart);
        buttons_panel.add(timer);

        panel.add(buttons_panel);
        panel.add(board);

        frame.add(panel, BorderLayout.NORTH);
        frame.pack();
        frame.setVisible(true);

        board.showAnswer();

    }
}

