public class AnotherGame {
    private static JFrame frame;
    private static JPanel panel;
    private static JPanel top_panel;
    private static JPanel buttons_panel;
    private static AnotherBoard board;
    private static JLabel textfield;
    private static JLabel mines_label;
    private static JButton restart_button;
    private static JLabel timer_label;

    private static Timer timer = new Timer();
    private static Integer sec = 0;


    public static void main(String args[]) {
        Dimension dimension = Toolkit.getDefaultToolkit().getScreenSize();

        int x = (int) (dimension.getWidth() / 3);
        int y = 0;

        // panel
        panel = new JPanel();
        BoxLayout boxLayout = new BoxLayout(panel, BoxLayout.Y_AXIS);
        panel.setLayout(boxLayout);

        // top_panel (contains game's title)
        top_panel = new JPanel();
        top_panel.setLayout(new BorderLayout());
        top_panel.setBounds(0, 0, 600, 100);

        // buttons_panel (contains 3 panels/ buttons, below top_panel)
        FlowLayout flowLayout = new FlowLayout(FlowLayout.LEFT, 90, 0);
        buttons_panel = new JPanel();
        buttons_panel.setLayout(flowLayout);
        buttons_panel.setPreferredSize(new Dimension(600, 50));
        buttons_panel.setBackground(new Color(52, 186, 235));

        // board (below buttons_panel)
        board = new AnotherBoard(10, 10);
        board.setPreferredSize(new Dimension(600, 600));

        // textfield (insode top_panel)
        textfield = new JLabel();
        textfield.setBackground(new Color(13, 33, 54));
        textfield.setForeground(new Color(255, 255, 255));
        textfield.setHorizontalAlignment(JLabel.CENTER);
        textfield.setFont(new Font("MVBoli", Font.PLAIN,60));
        textfield.setText("MINESWEEPER");
        textfield.setOpaque(true);
        top_panel.add(textfield);

        Border blackline = BorderFactory.createLineBorder(Color.black);

        // mines_label (first button inside buttons_panel)
        mines_label = board.Interactive(board);

        // restart_button (second button inside buttons_panel)
        restart_button = new JButton("Restart");
        //restart_button.setPreferredSize(new Dimension(120, 50));

        restart_button.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                restartGame();
            }
        });

        // timer_label (last label inside buttons_label)
        //timer_label = new JLabel("0", SwingConstants.CENTER);
        timer_label = new JLabel();
        timer_label.setPreferredSize(new Dimension(80, 50));
        timer_label.setBackground(Color.WHITE);
        timer_label.setOpaque(true);
        timer_label.setBorder(blackline);
        timer_label.setFont(new Font("MVBoli", Font.PLAIN, 20));
        timer_label.setVerticalTextPosition(JLabel.CENTER);
        timer_label.setHorizontalTextPosition(JLabel.CENTER);
        timer_label.setText("0");

        buttons_panel.add(mines_label);
        buttons_panel.add(restart_button);
        buttons_panel.add(timer_label);

        // timer (inside timer_label)
        timer = new Timer();

        panel.add(top_panel);
        panel.add(buttons_panel);
        panel.add(board);

        // frame
        frame = new JFrame();
        frame.setBounds(0, 0, 600, 750);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setResizable(false);

        frame.setLocation(x, y);
        frame.add(panel, BorderLayout.NORTH);
        frame.pack();
        frame.setVisible(true);

    }

