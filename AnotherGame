    private static void restartGame() {
        board.reset();
        sec = 0;
        timer_label.setText("0");
        timer.cancel();
        timer = new Timer();
    }

    public static void startCountTime() {
        timer.scheduleAtFixedRate(new TimerTask() {
            @Override
            public void run() {
                sec++;
                String value = sec.toString();

                timer_label.setFont(new Font("MVBoli", Font.PLAIN, 20));
                timer_label.setVerticalTextPosition(JLabel.CENTER);
                timer_label.setHorizontalTextPosition(JLabel.CENTER);
                timer_label.setText(value);
            }
        }, 1000, 1000);
    }

    public static void stopCountTime() {
        timer.cancel();
    }

}
